# Supabase — copy to .env for local; MUST also set in Vercel Project Settings
# (Production + Preview) or /api/env.js will inject empty strings and deletes fail.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Aliases also accepted by /api/env.js:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Domain hints (used by api/gateway.js for server-side routing metadata)
STOREFRONT_HOST=store.com
ADMIN_HOST=admin.store.com
POS_HOST=pos.store.com

# UPAY credit card gateway (optional — demo mode without these)
UPAY_MERCHANT_ID=
UPAY_API_KEY=
UPAY_API_URL=https://api.upay.ae/v1/charges

# Supabase service role for server-side order storage + users table auth
SUPABASE_SERVICE_ROLE_KEY=

# ── Authentication ──────────────────────────────────────────────────
# HMAC secret for signed session cookies (required in production)
AUTH_SESSION_SECRET=change-me-to-a-long-random-string

# Demo / bootstrap admin (used when `users` table is empty)
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=shamaadan
# Legacy alias — also accepted as demo admin password
ADMIN_PIN=shamaadan

# Demo / bootstrap POS staff PIN (4–8 digits)
AUTH_STAFF_PIN=1234
AUTH_STAFF_NAME=Cashier

# Cloudflare R2 image storage (optional — local preview works until configured)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shamaadan
R2_PUBLIC_BASE_URL=https://pub-3314509d6af24c65be2310ded2efa6e2.r2.dev
