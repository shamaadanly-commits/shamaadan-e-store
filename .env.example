# Supabase — copy to .env.local for local dev; set in Vercel Project Settings for production
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Domain hints (used by api/gateway.js for server-side routing metadata)
STOREFRONT_HOST=store.com
ADMIN_HOST=admin.store.com
POS_HOST=pos.store.com

# UPAY credit card gateway (optional — demo mode without these)
UPAY_MERCHANT_ID=
UPAY_API_KEY=
UPAY_API_URL=https://api.upay.ae/v1/charges

# Supabase service role for server-side order storage (optional)
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard access PIN (optional — defaults to shamaadan in dev)
ADMIN_PIN=shamaadan

# Cloudflare R2 image storage (optional — local preview works until configured)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shamaadan-products
R2_PUBLIC_BASE_URL=https://cdn.shamaadan.ly
